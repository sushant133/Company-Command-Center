# Backend Environment Variables
# Copy to .env and NEVER commit .env to git!

# ========================================
# SERVER & DATABASE
# ========================================
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/companycenter
MONGODB_DEBUG=false  # Set true for query logging

# ========================================
# JWT & AUTH (GENERATE SECURE SECRETS!)
# ========================================
JWT_SECRET=your-super-secure-64-char-secret-here-use-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173  # Frontend origin

# ========================================
# EMAIL (OTP, Notifications)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password  # Gmail App Password!
SMTP_FROM=noreply@companycenter.com

# ========================================
# FILE UPLOADS
# ========================================
UPLOAD_MAX_SIZE=5242880  # 5MB
UPLOAD_PATH=./uploads

# ========================================
# AI & CACHING (Optional)
# ========================================
AI_CACHE_TTL=3600  # 1 hour
REDIS_URL=redis://localhost:6379  # Production caching

# ========================================
# PRODUCTION SECURITY
# ========================================
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
TRUST_PROXY=loopback  # Nginx/PM2

# SECURITY NOTES:
# 1. Generate JWT_SECRET: openssl rand -hex 32
# 2. Use MongoDB Atlas + IP whitelist for prod
# 3. Enable HTTPS + Helmet CSP
# 4. Redis for token blacklist in prod
# 5. Never expose .env - use Docker secrets/PM2 ecosystem
